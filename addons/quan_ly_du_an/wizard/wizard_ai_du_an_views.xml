<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_wizard_ai_du_an_form" model="ir.ui.view">
            <field name="name">wizard.ai_du_an.form</field>
            <field name="model">wizard.ai_du_an</field>
            <field name="arch" type="xml">
                <form string="🤖 Trợ lý AI Dự án">
                    <sheet>
                        <!-- API Key & Dự án -->
                        <group string="Cấu hình">
                            <field name="du_an_id" options="{'no_create': True}"/>
                            <field name="api_key" password="True"
                                   placeholder="sk-ant-api03-... (lấy tại console.anthropic.com)"/>
                            <field name="che_do" widget="radio"/>
                        </group>

                        <group string="📋 Dữ liệu dự án gửi cho AI" col="1">
                            <field name="thong_tin_du_an" nolabel="1" readonly="1"
                                   style="font-family:monospace;font-size:11px;background:#f5f5f5;padding:8px;white-space:pre-wrap;"/>
                        </group>

                        <!-- CHATBOT -->
                        <group string="💬 Hỏi đáp với AI"
                               attrs="{'invisible': [('che_do','!=','chatbot')]}">
                            <field name="cau_hoi" nolabel="1" col="1"
                                   placeholder="Ví dụ: Dự án đang tiến độ thế nào? / Ai đang có việc quá hạn? / Đề xuất cải thiện tiến độ dự án?"
                                   style="min-height:80px;"/>
                            <div col="1">
                                <button name="action_hoi_ai" string="🚀 Hỏi AI" type="object"
                                        class="btn-primary"/>
                                <button name="action_luu_api_key" string="💾 Lưu API Key" type="object"
                                        class="btn-secondary ml-2"
                                        attrs="{'invisible': [('api_key','=',False)]}"/>
                            </div>
                            <field name="tra_loi" nolabel="1" col="1" widget="html"
                                   attrs="{'invisible': [('tra_loi','=',False)]}"/>
                        </group>

                        <!-- PHÂN CÔNG -->
                        <group string="🤖 AI đề xuất phân công công việc"
                               attrs="{'invisible': [('che_do','!=','phan_cong')]}">
                            <field name="yeu_cau_pc" nolabel="1" col="1"
                                   placeholder="VD: Tạo công việc phù hợp với chức vụ của từng thành viên, tập trung vào giai đoạn phát triển"
                                   style="min-height:60px;"/>
                            <div col="1">
                                <button name="action_ai_phan_cong"
                                        string="🤖 AI Phân tích &amp; Tạo công việc"
                                        type="object" class="btn-primary"/>
                            </div>
                            <field name="ket_qua_pc" nolabel="1" col="1" widget="html"
                                   attrs="{'invisible': [('ket_qua_pc','=',False)]}"/>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Đóng" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_wizard_ai_du_an" model="ir.actions.act_window">
            <field name="name">🤖 Trợ lý AI Dự án</field>
            <field name="res_model">wizard.ai_du_an</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
