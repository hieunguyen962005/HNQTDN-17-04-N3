<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_wizard_phan_cong_form" model="ir.ui.view">
            <field name="name">wizard.phan_cong_cong_viec.form</field>
            <field name="model">wizard.phan_cong_cong_viec</field>
            <field name="arch" type="xml">
                <form string="Phân công công việc hàng loạt">
                    <sheet>
                        <group string="Thông tin công việc">
                            <field name="du_an_id"/>
                            <field name="ten_cong_viec"/>
                            <field name="loai_cv"/>
                            <field name="do_uu_tien" widget="priority"/>
                            <field name="ngay_bat_dau"/>
                            <field name="deadline"/>
                        </group>
                        <group string="Nhân viên phụ trách">
                            <field name="thanh_vien_du_an_ids" invisible="1"/>
                            <field name="nhan_vien_ids" widget="many2many_tags"
                                   options="{'no_create': True}"
                                   help="Chỉ hiển thị thành viên của dự án đã chọn"/>
                            <field name="nhan_vien_ids">
                                <tree>
                                    <field name="ho_va_ten"/>
                                    <field name="chuc_vu_id"/>
                                    <field name="don_vi_id"/>
                                </tree>
                            </field>
                        </group>
                        <group string="Mô tả chi tiết">
                            <field name="mo_ta" nolabel="1" placeholder="Mô tả chi tiết công việc..."/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_phan_cong" string="✅ Phân công" type="object"
                                class="btn-primary"/>
                        <button string="Huỷ" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_wizard_phan_cong" model="ir.actions.act_window">
            <field name="name">Phân công công việc hàng loạt</field>
            <field name="res_model">wizard.phan_cong_cong_viec</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
