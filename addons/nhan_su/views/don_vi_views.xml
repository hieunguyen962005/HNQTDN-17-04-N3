<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_don_vi_form" model="ir.ui.view">
            <field name="name">don_vi.form</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <form string="Đơn vị / Phòng ban">
                    <sheet>
                        <group>
                            <group string="Thông tin đơn vị">
                                <field name="ma_don_vi"/>
                                <field name="ten_don_vi"/>
                                <field name="truong_don_vi_id"/>
                                <field name="so_nhan_vien"/>
                            </group>
                            <group string="Mô tả">
                                <field name="mo_ta" nolabel="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Danh sách nhân viên">
                                <field name="nhan_vien_ids">
                                    <tree>
                                        <field name="ma_dinh_danh"/>
                                        <field name="ho_va_ten"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="trang_thai" widget="badge"
                                               decoration-success="trang_thai=='dang_lam'"
                                               decoration-warning="trang_thai=='tam_nghi'"
                                               decoration-danger="trang_thai=='nghi_viec'"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_don_vi_tree" model="ir.ui.view">
            <field name="name">don_vi.tree</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <tree string="Đơn vị">
                    <field name="ma_don_vi"/>
                    <field name="ten_don_vi"/>
                    <field name="truong_don_vi_id"/>
                    <field name="so_nhan_vien"/>
                </tree>
            </field>
        </record>
        <record id="action_don_vi" model="ir.actions.act_window">
            <field name="name">Đơn vị / Phòng ban</field>
            <field name="res_model">don_vi</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
