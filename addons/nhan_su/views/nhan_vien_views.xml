<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- FORM -->
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan_vien.form</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form string="Hồ sơ nhân viên">
                    <header>
                        <field name="trang_thai" widget="statusbar"
                               statusbar_visible="dang_lam,tam_nghi,nghi_viec"
                               statusbar_colors='{"tam_nghi": "warning", "nghi_viec": "danger"}'/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object"
                                    name="action_xem_du_an" icon="fa-briefcase"
                                    attrs="{'invisible': [('so_du_an_tham_gia','=',0)]}">
                                <field name="so_du_an_tham_gia" widget="statinfo" string="Dự án"/>
                            </button>
                            <button class="oe_stat_button" type="object"
                                    name="action_xem_cong_viec" icon="fa-tasks"
                                    attrs="{'invisible': [('so_cong_viec_dang_lam','=',0)]}">
                                <field name="so_cong_viec_dang_lam" widget="statinfo" string="Công việc"/>
                            </button>
                        </div>
                        <field name="anh" widget="image" class="oe_avatar"
                               options="{'preview_image': 'anh'}"/>
                        <div class="oe_title">
                            <h1><field name="ho_va_ten" readonly="1"/></h1>
                            <h2><field name="chuc_vu_id" placeholder="Chức vụ..."/></h2>
                        </div>
                        <group>
                            <group string="Thông tin cá nhân">
                                <field name="ho_ten_dem"/>
                                <field name="ten"/>
                                <field name="ma_dinh_danh"/>
                                <field name="gioi_tinh" widget="radio"/>
                                <field name="ngay_sinh"/>
                                <field name="tuoi"/>
                                <field name="que_quan"/>
                                <field name="dia_chi"/>
                            </group>
                            <group string="Thông tin liên hệ &amp; Công tác">
                                <field name="email" widget="email"/>
                                <field name="so_dien_thoai" widget="phone"/>
                                <field name="don_vi_id"/>
                                <field name="ngay_vao_lam"/>
                                <field name="trang_thai" widget="selection"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lịch sử công tác">
                                <field name="lich_su_cong_tac_ids">
                                    <tree editable="bottom">
                                        <field name="chuc_vu_id"/>
                                        <field name="don_vi_id"/>
                                        <field name="loai_chuc_vu"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="ghi_chu"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Chứng chỉ / Bằng cấp">
                                <field name="danh_sach_chung_chi_bang_cap_ids">
                                    <tree editable="bottom">
                                        <field name="chung_chi_bang_cap_id"/>
                                        <field name="ngay_cap"/>
                                        <field name="noi_cap"/>
                                        <field name="ngay_het_han"/>
                                        <field name="ghi_chu"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- TREE -->
        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan_vien.tree</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree string="Danh sách nhân viên"
                      decoration-muted="trang_thai == 'nghi_viec'"
                      decoration-warning="trang_thai == 'tam_nghi'">
                    <field name="ma_dinh_danh"/>
                    <field name="ho_va_ten"/>
                    <field name="gioi_tinh"/>
                    <field name="don_vi_id"/>
                    <field name="chuc_vu_id"/>
                    <field name="email"/>
                    <field name="so_dien_thoai"/>
                    <field name="ngay_vao_lam"/>
                    <field name="trang_thai" widget="badge"
                           decoration-success="trang_thai=='dang_lam'"
                           decoration-warning="trang_thai=='tam_nghi'"
                           decoration-danger="trang_thai=='nghi_viec'"/>
                </tree>
            </field>
        </record>

        <!-- SEARCH -->
        <record id="view_nhan_vien_search" model="ir.ui.view">
            <field name="name">nhan_vien.search</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm nhân viên">
                    <field name="ho_va_ten"/>
                    <field name="ma_dinh_danh"/>
                    <field name="email"/>
                    <field name="don_vi_id"/>
                    <field name="chuc_vu_id"/>
                    <separator/>
                    <filter string="Đang làm việc" name="dang_lam" domain="[('trang_thai','=','dang_lam')]"/>
                    <filter string="Tạm nghỉ"       name="tam_nghi" domain="[('trang_thai','=','tam_nghi')]"/>
                    <filter string="Đã nghỉ việc"   name="nghi_viec" domain="[('trang_thai','=','nghi_viec')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Đơn vị"     name="group_don_vi"    context="{'group_by':'don_vi_id'}"/>
                        <filter string="Chức vụ"    name="group_chuc_vu"   context="{'group_by':'chuc_vu_id'}"/>
                        <filter string="Trạng thái" name="group_tt"        context="{'group_by':'trang_thai'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ACTION -->
        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_nhan_vien_search"/>
            <field name="context">{'search_default_dang_lam': 1}</field>
        </record>
    </data>
</odoo>
